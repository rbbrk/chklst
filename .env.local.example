# Google OAuth — create credentials at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The only Google account allowed to sign in
ALLOWED_EMAIL=you@gmail.com

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Upstash Redis — add a Redis integration from vercel.com/marketplace, then run:
#   vercel link
#   vercel env pull .env.local
# This will populate the UPSTASH_* vars automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# For local dev, use `vercel dev` (instead of `npm run dev`) to auto-inject these vars
